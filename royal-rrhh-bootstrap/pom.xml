    </dependency>
    <dependency>
        <groupId>net.royal.erp</groupId>
        <artifactId>royal-framework-security</artifactId>
        <version>${project.version}</version>
    </dependency>
    <dependency>
        <groupId>net.royal.erp</groupId>
        <artifactId>royal-framework-audit</artifactId>
        <version>${project.version}</version>
    </dependency>
    <dependency>
        <groupId>net.royal.erp</groupId>
        <artifactId>royal-framework-versioning</artifactId>
        <version>${project.version}</version>
    </dependency>
    <dependency>
        <groupId>net.royal.erp</groupId>
        <artifactId>royal-framework-licensing</artifactId>
        <version>${project.version}</version>
    </dependency>
    <dependency>
        <groupId>net.royal.erp</groupId>
        <artifactId>royal-framework-observability</artifactId>
