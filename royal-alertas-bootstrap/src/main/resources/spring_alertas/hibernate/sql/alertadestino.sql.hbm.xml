<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <sql-query name="alertadestino.xxxxxx">
         select GETDATE()
    </sql-query>

    <sql-query name="alertadestino.listarPorIdAlertaSentencia">
         SELECT CORREO_DESTINO as "correoDestino"
		FROM SGALERTASSYS.ALERTA_DESTINO with (nolock)
		WHERE ID_ALERTA = :p_idAlerta
		GROUP BY CORREO_DESTINO
    </sql-query>

</hibernate-mapping>
